generator client {
  provider = "prisma-client-js"
}

// Para testes locais, usando SQLite.
// Para produção com SQL Server, troque para:
//   provider = "sqlserver"
//   url      = env("DATABASE_URL")
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Responsavel {
  id           Int      @id @default(autoincrement())
  nomeCompleto String   @map("nome_completo")
  cpf          String   @unique
  whatsapp     String
  dataCadastro DateTime @default(now()) @map("data_cadastro")

  alunos Aluno[]

  @@map("Responsaveis")
}

model Aluno {
  id                 Int      @id @default(autoincrement())
  responsavelId      Int      @map("responsavel_id")
  nomeCompleto       String   @map("nome_completo")
  dataNascimento     DateTime @map("data_nascimento")
  categoria          String?
  informacoesMedicas String?  @map("informacoes_medicas")
  status             String   @default("Lead")
  dataCadastro       DateTime @default(now()) @map("data_cadastro")

  responsavel  Responsavel   @relation(fields: [responsavelId], references: [id])
  mensalidades Mensalidade[]

  @@map("Alunos")
}

model Mensalidade {
  id             Int      @id @default(autoincrement())
  alunoId        Int      @map("aluno_id")
  mesReferencia  String   @map("mes_referencia")
  valor          Decimal
  dataVencimento DateTime @map("data_vencimento")
  status         String   @default("Pendente")
  dataCriacao    DateTime @default(now()) @map("data_criacao")

  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("Mensalidades")
}
